# Copier ce fichier en « .env » et adapter les valeurs.
# (Next.js charge automatiquement ce fichier à la racine du projet.)

# ─── Base de données MariaDB / MySQL (format Prisma) ─────────────────────────
# Remplacer les valeurs par vos identifiants réels.
DATABASE_URL="mysql://root:a_renseigner@localhost:3306/facturasso"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT : mettre une longue chaîne aléatoire en production.
# Générer une valeur sûre avec :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=a-changer-par-une-longue-chaine-aleatoire
JWT_DUREE=8h

# ─── Licences Exoria ─────────────────────────────────────────────────────────
# Mettre à true en développement pour bypasser la vérification de licence.
LICENCE_DEV_BYPASS=true

# Renseigner en production avec les clés fournies par Exoria.
EXORIA_API_URL=
EXORIA_API_TOKEN=
EXORIA_LICENCE_UUID=
EXORIA_ENCRYPTION_PASSWORD=

# ─── Seed : compte superviseur ───────────────────────────────────────────────
# Ces valeurs sont utilisées par `npx prisma db seed` pour créer le compte superviseur.
SEED_SUPERVISEUR_NOM=superviseur
SEED_SUPERVISEUR_EMAIL=superviseur@example.com
SEED_SUPERVISEUR_MOT_DE_PASSE=a-changer
