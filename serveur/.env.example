# Copier ce fichier en « .env » et adapter les valeurs.

# Port d'écoute du serveur API
PORT=4000

# Connexion à la base de données MariaDB / MySQL
BDD_HOTE=localhost
BDD_PORT=3306
BDD_UTILISATEUR=root
BDD_MOT_DE_PASSE=
BDD_NOM=facturasso

# Clé secrète servant à signer les jetons de connexion (JWT).
# IMPORTANT : mettre une longue chaîne aléatoire en production.
JWT_SECRET=a-changer-par-une-longue-chaine-aleatoire
JWT_DUREE=8h

# Adresse du front autorisée à appeler l'API (CORS)
ORIGINE_CLIENT=http://localhost:5173
