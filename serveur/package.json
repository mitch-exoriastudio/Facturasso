{
  "name": "facturasso-serveur",
  "version": "2.0.0",
  "description": "API back-end de Facturasso (Express + MariaDB via Prisma)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "creer-admin": "node scripts/creer-admin.js",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "prisma db seed",
